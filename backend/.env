# ═══════════════════════════════════════════════════════
#  Powerhouse Gym & Spa — Backend Configuration
#  Fill in your values and save as .env
# ═══════════════════════════════════════════════════════

# ── MongoDB Atlas ────────────────────────────────────────
# Get from: cloud.mongodb.com → Connect → Drivers
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/powerhousegym

# ── Gmail (for email notifications) ─────────────────────
# Use Gmail App Password — NOT your real password
# Enable at: myaccount.google.com → Security → App passwords
EMAIL_USER=yourgmail@gmail.com
EMAIL_PASS=xxxx xxxx xxxx xxxx
EMAIL_TO=team@powerhousegymandspa.in

# ── Server Port ──────────────────────────────────────────
PORT=5000
